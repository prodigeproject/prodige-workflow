diff --git a/src/auth/login.js b/src/auth/login.js
index 1111111..2222222 100644
--- a/src/auth/login.js
+++ b/src/auth/login.js
@@ -7,6 +7,20 @@ const db = require('../db');
 // Body is validated by zod schema in route middleware (see routes/auth.js).
 async function login(req, res) {
   const { username, password } = req.body;
+
+  // BUG (line ~23): username interpolated straight into SQL -> injection.
+  const row = await db.query(
+    `SELECT id, pwd_hash FROM users WHERE name = '${username}'`
+  );
+  if (!row) return res.status(401).json({ error: 'invalid' });
+
+  const ok = await verify(password, row.pwd_hash);
+  return ok ? res.json({ token: sign(row.id) }) : res.status(401).json({ error: 'invalid' });
 }
+
+// Scope creep: unrelated reset-flow refactor bundled into this change.
