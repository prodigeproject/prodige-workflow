# Prodige Workflow .gitignore

# ============================================================================
# Runtime State (DO NOT COMMIT)
# ============================================================================
# These directories contain session-specific runtime state that should not
# be version controlled. They are generated fresh each session.

.ai/runtime/
.ai/runtime/**/*

# Specific runtime subdirectories
.ai/runtime/briefs/
.ai/runtime/cache/
.ai/runtime/handoffs/
.ai/runtime/locks/
.ai/runtime/queue/
.ai/runtime/sessions/
.ai/runtime/snapshots/
.ai/runtime/worktrees/

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
*.log
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================================
# IDE and Editor Files
# ============================================================================
.vscode/
.idea/
*.sublime-*
.vs/

# ============================================================================
# Node.js (if applicable to your project)
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================================================
# Python (if applicable to your project)
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/

# ============================================================================
# Environment Variables (SECURITY)
# ============================================================================
.env
.env.local
.env.*.local
*.key
*.pem
secrets.*

# ============================================================================
# Build Artifacts
# ============================================================================
dist/
build/
out/
target/
*.o
*.a
*.exe

# ============================================================================
# Test Coverage
# ============================================================================
coverage/
.nyc_output/
*.lcov

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================================
# Keep Structure (placeholder files are committed)
# ============================================================================
!.ai/runtime/.gitkeep
!.ai/runtime/*/.gitkeep

# ============================================================================
# Optional: Large Files (if you want to exclude them)
# ============================================================================
# *.pdf
# *.zip
# *.tar.gz
# *.mp4
# *.mov

# ============================================================================
# Git
# ============================================================================
*.orig

# ============================================================================
# Memory Bank - Semantic Cache (DO NOT COMMIT)
# ============================================================================
# Optional, opt-in semantic search backend. This is a derived SQLite cache
# rebuildable from the canonical markdown (.ai/memory/*.md). It must never be
# committed. See .ai/docs/semantic-memory-backend.md.
.ai/memory/.cache/
